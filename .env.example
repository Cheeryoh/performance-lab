# Supabase — shared project with candidate portal
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# GitHub — Personal Access Token (demo scale; migrate to GitHub App for production)
# Required scopes: repo (full), codespace (full)
GITHUB_PAT=your-github-pat
GITHUB_ORG=your-github-org-or-username
BROKEN_REPO_TEMPLATE=your-broken-repo-template-name

# App URLs
EXAM_ENVIRONMENT_BASE_URL=https://your-performance-lab.vercel.app
CANDIDATE_PORTAL_URL=https://cert-candidate-portal.vercel.app

# Claude API — server-side only, for 4D qualitative scoring
ANTHROPIC_API_KEY=your-anthropic-api-key
